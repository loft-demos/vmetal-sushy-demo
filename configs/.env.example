# vmetal-sushy-demo configuration
# Copy this file to .env and adjust values for your environment.
# All scripts source .env from the repo root if it exists.

# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------

# Name of the Linux bridge used for provisioning / PXE traffic.
# Metal3/Ironic will own DHCP on this network — do NOT run another DHCP server on it.
PROVISION_BRIDGE=br-provision

# IP address assigned to the bridge on the host.
# This address must be reachable by the sushy-tools process and by Ironic
# (which runs inside vCluster and needs to reach Sushy's Redfish endpoint).
PROVISION_IP=172.22.0.1

# Subnet CIDR for the provisioning network.
PROVISION_CIDR=172.22.0.0/24

# ---------------------------------------------------------------------------
# LAN / demo domain
# ---------------------------------------------------------------------------

# The network interface connected to your LAN (internet-facing NIC).
# Used by create-bridges.sh to set up NAT masquerade so provisioning VMs
# can reach the internet for DNS and container image pulls.
# IMPORTANT: Set this to your actual outbound interface before running
# create-bridges.sh — wrong value = VMs can't pull images.
# Check with: ip route show default   (look for 'dev <interface>')
# Common values: enp1s0, enp197s0, eth0, eno1
LAN_INTERFACE=enp1s0

# The host machine's own LAN IP address (on LAN_INTERFACE).
# Used by hack/setup-mac-dns.sh to point the Mac's resolver at this host.
# Find it with: ip -4 addr show $LAN_INTERFACE
LAN_IP=

# Local demo domain — all demo services live under this domain.
# A Gateway listens for *.VDEMO_DOMAIN and routes by hostname.
# dnsmasq on the host resolves *.VDEMO_DOMAIN → GATEWAY_IP.
# Your Mac only needs /etc/resolver/VDEMO_DOMAIN pointing at LAN_IP.
VDEMO_DOMAIN=vdemo.local

# IP assigned to the Gateway's LoadBalancer service by MetalLB.
# Must be on the same LAN subnet as LAN_INTERFACE, outside your router's DHCP range.
# All *.VDEMO_DOMAIN traffic from your Mac arrives at this single IP.
GATEWAY_IP=192.168.1.200

# MetalLB pool range — set to a single IP for a single-machine demo.
METALLB_IP_RANGE=192.168.1.200-192.168.1.200

# ---------------------------------------------------------------------------
# Sushy Tools (Redfish BMC emulator)
# ---------------------------------------------------------------------------

# Port sushy-tools listens on.
SUSHY_PORT=8000

# libvirt connection URI. Use qemu:///system to connect as root/via socket.
SUSHY_LIBVIRT_URI=qemu:///system

# IP address sushy-tools binds to. Empty string means all interfaces.
# The value of PROVISION_IP is a good explicit choice so the endpoint is
# reachable from VMs and from within the vCluster network.
SUSHY_LISTEN_IP=

# Path to the sushy-tools Python virtualenv.
SUSHY_VENV=/opt/sushy-tools

# Path used to install the sushy-tools config.
SUSHY_CONF_DIR=/etc/sushy-tools

# ---------------------------------------------------------------------------
# BMC credentials
# These are embedded in the sushy-tools auth file (if enabled) AND used when
# generating the Kubernetes Secret manifests for BareMetalHost resources.
# ---------------------------------------------------------------------------

BMC_USERNAME=admin
BMC_PASSWORD=password

# ---------------------------------------------------------------------------
# VM profiles
# Two sizes are provided: small (worker nodes, light workloads) and
# large (GPU-class or compute-heavy demo nodes).
# Adjust to fit available hardware; on a 64 GB host the defaults leave
# headroom for vCluster Platform + Metal3/Ironic overhead.
# ---------------------------------------------------------------------------

# Small VM profile — suitable for lightweight bare-metal worker nodes
SMALL_VM_COUNT=3
SMALL_VM_VCPUS=2
SMALL_VM_RAM_MB=4096
SMALL_VM_DISK_GB=40
SMALL_VM_NAME_PREFIX=vmetal-small

# Large VM profile — suitable for compute-heavy or GPU-demo nodes
LARGE_VM_COUNT=2
LARGE_VM_VCPUS=4
LARGE_VM_RAM_MB=8192
LARGE_VM_DISK_GB=80
LARGE_VM_NAME_PREFIX=vmetal-large

# Directory where VM disk images are stored.
# Recommendation: point this at one of the 2 TB NVMe SSDs for better I/O.
# Example: VM_IMAGE_DIR=/mnt/nvme0/libvirt/images
# Default uses the standard libvirt pool on the OS SSD.
VM_IMAGE_DIR=/var/lib/libvirt/images

# ---------------------------------------------------------------------------
# vCluster Standalone + vCluster Platform
# ---------------------------------------------------------------------------

# vCluster Standalone binary version.
VCLUSTER_VERSION=latest

# Name for this vCluster Standalone instance.
VCLUSTER_NAME=vmetal-demo

# Kubernetes version to run inside vCluster Standalone.
K8S_VERSION=v1.35.1

# ---------------------------------------------------------------------------
# vCluster Platform (installed via experimental.deploy.vcluster.helm)
# ---------------------------------------------------------------------------

# Helm chart version for vcluster-platform.
# Find latest: helm search repo loft/vcluster-platform --versions
VCP_PLATFORM_VERSION=4.8.0

# Scale tier license token. Set this before running install-vcluster.sh.
# Do NOT commit a real token to git — keep it in .env (which is gitignored).
VCP_LICENSE_TOKEN=

# FQDN for the vCluster Platform UI.
# This is a subdomain of VDEMO_DOMAIN routed by the Gateway.
# vCP uses it for cookie domains, OAuth redirects, and self-referencing URLs.
VCP_LOFT_HOST=vcp.vdemo.local

# ---------------------------------------------------------------------------
# Gateway (Traefik v3 — Gateway API implementation)
# Helm chart version for Traefik.
# Find latest: helm search repo traefik/traefik --versions | head
# ---------------------------------------------------------------------------

TRAEFIK_VERSION=39.0.6

# ---------------------------------------------------------------------------
# BareMetalHost provisioning IPs
# The vCP DHCP proxy assigns static IPs to VMs during PXE/inspection.
# These IPs must be on PROVISION_CIDR and not conflict with PROVISION_IP (.1)
# or the DHCP VIP (.2). Default starts at .11.
# ---------------------------------------------------------------------------

PROVISION_GATEWAY=172.22.0.1
VM_IP_START=172.22.0.11

# ---------------------------------------------------------------------------
# OS Image cache server
# Serves OS images locally so the IPA ramdisk (which has no DNS/internet)
# can fetch them. Run scripts/cache-os-image.sh to populate and start it.
# ---------------------------------------------------------------------------

# Port the image HTTP server listens on (on PROVISION_IP).
IMAGE_SERVER_PORT=9000

# Directory where downloaded OS images are stored.
IMAGE_CACHE_DIR=/srv/os-images
